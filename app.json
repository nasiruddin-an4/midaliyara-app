{
  "expo": {
    "name": "midaliaya-app",
    "slug": "midaliaya-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/mainLogo.png",
    "scheme": "midaliayaapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/mainLogo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.midaliayaapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/mainLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/mainLogo.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9c060858-a033-4098-adb6-d42764c2423f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9c060858-a033-4098-adb6-d42764c2423f"
    }
  }
}
